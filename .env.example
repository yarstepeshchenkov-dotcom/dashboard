# === Авторизация ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_please
SECRET_KEY=change_this_to_a_long_random_string

# === База данных ===
# Путь к существующей БД бота. Если не указан — используется значение по умолчанию ниже.
DB_PATH=/root/lithium_bot/data/lithium.db

# === Проверка сайта ===
SITE_URL=https://lithiumhome.ru

# === Email-уведомления (опционально) ===
# Если EMAIL_ENABLED=false — письма не отправляются, даже если остальные поля заполнены.
EMAIL_ENABLED=false
EMAIL_FROM=your@email.com
EMAIL_TO=admin@email.com
SMTP_SERVER=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_login
SMTP_PASS=your_password

# === Пороги для критических уведомлений ===
NEGATIVE_ALERT_THRESHOLD=5
ALERT_WINDOW_MINUTES=60
BACKGROUND_CHECK_INTERVAL_SECONDS=300
